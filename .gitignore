### Ignore these paths or file types
# Root-level build / dependency artifacts. The frontend/ patterns below
# do not cover stray copies committed at the repo root (e.g. a root
# .next/trace from a Vercel build, or a root node_modules vitest cache).
/.next/
/node_modules/
# No trailing slash so a node_modules SYMLINK (created in a worktree) is also
# ignored, the dir-only pattern above misses the symlink form (the cause of a
# bad merge that committed self-referential node_modules symlinks, 2026-06-07).
/node_modules
/out/

# Next.js
frontend/.next/
frontend/out/

# Dependencies
frontend/node_modules/
# No trailing slash, also ignore the symlink form (see note above).
frontend/node_modules

# Production
frontend/build/

# Test artifacts
frontend/coverage/
frontend/playwright-report/
frontend/playwright/.cache/
frontend/test-results/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local env files
frontend/.env*.local

# TypeScript build info
frontend/tsconfig.tsbuildinfo

# OS files
.DS_Store

# ELN-import sub-bot scratch (sample ZIP recon dir + ad-hoc parser dump)
scratch-labarchives-recon/
frontend/scratch-parse-output.json

# Per-developer agent state (worktrees, session logs, transcripts, agent caches)
.claude/

# Kilo Code plugin state, fully per-developer, not tracked.
.kilo/

# DNA feature DB build cache (re-fetchable from NCBI; not tracked)
scripts/.dna-feature-cache/

# Taxonomy backbone build temp (the raw NCBI taxdump zip + dmp files; re-downloadable, not tracked)
tools/taxonomy-backbone/.taxdump-tmp/
.vercel
.env*
# ...but keep the checked-in env template (placeholders only, no secrets).
!frontend/.env.example

# Raw demo screen recordings for the /welcome redesign (large, re-recordable; not tracked)
demo-recordings/
# Local clip-review scratch harness for the /welcome video showcases (served preview, re-generatable)
frontend/public/_clipreview/
ResearchOS_Beta_Testers.xlsx
ResearchOS_Beta_Tracker.html
scripts/activity-report/.venv/
# commit-map.json is committed (it is the product of an expensive agent pass).
# Scratch files from the reclassification workflow are not:
scripts/activity-report/_commit-data.json
scripts/activity-report/_batches/
scripts/activity-report/_agent-map.json
scripts/activity-report/_milestones_block.txt

# Privacy guard local denylist (repo is public): the specific sensitive terms
# the pre-commit privacy-guard catches (bank/brokerage names, address, etc.).
# Kept local so the denylist itself never lands in the public repo.
.privacy-denylist

# Wrangler local state/cache (Cloudflare). Never committed.
.wrangler/

# Business/financial reconciliation scripts (repo is public): one-off ledger
# and reimbursement helpers operate on private LLC accounting. Keep them out.
frontend/scripts/reimburse-*.mjs
