{
  "name": "collab-yjs-spike",
  "private": true,
  "version": "0.0.0",
  "description": "THROWAWAY proof-of-concept: two browser tabs live-editing one note through a local Cloudflare Durable Object Yjs hub. Not part of the main app.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build:client": "esbuild src/client.ts --bundle --format=esm --outfile=public/client.js --sourcemap",
    "watch:client": "esbuild src/client.ts --bundle --format=esm --outfile=public/client.js --sourcemap --watch",
    "verify": "node test/convergence.mjs"
  },
  "dependencies": {
    "@codemirror/commands": "6.10.3",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.43.0",
    "lib0": "0.2.99",
    "y-codemirror.next": "0.3.5",
    "y-protocols": "1.0.6",
    "yjs": "13.6.27"
  },
  "devDependencies": {
    "esbuild": "0.24.2",
    "ws": "8.18.0",
    "wrangler": "3.99.0"
  }
}
