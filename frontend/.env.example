# ResearchOS environment variables (example / template)
#
# Copy to .env.local for local dev, or set these in the Vercel project settings
# for production. Values here are PLACEHOLDERS, never real secrets. .env.local
# is gitignored; this .env.example is the checked-in reference.
#
# Everything below is for the OPTIONAL accounts / cross-boundary sharing
# backend. The core notebook (local folder, offline) needs NONE of these. If
# SHARING_ENABLED is not "true", every directory + relay route is off and the
# app runs as a pure local notebook.
#
# Required-for-sharing vars are marked [REQUIRED]. Per-provider and feature
# vars are marked [OPTIONAL].

# ─────────────────────────────────────────────────────────────────────────────
# Master gate
# ─────────────────────────────────────────────────────────────────────────────
# [REQUIRED for sharing] The kill-switch. Must be exactly "true" or the entire
# accounts/sharing backend stays off and sign-in does nothing. Most-forgotten
# var on first deploy.
SHARING_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# Auth (Auth.js / NextAuth) — read internally by the library
# ─────────────────────────────────────────────────────────────────────────────
# [REQUIRED] Signs the JWT session. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Each sign-in button needs its matching pair. A provider is only wired in when
# its _ID is present, so you can ship a subset of the four buttons. Also
# register the redirect URI in each provider console:
#   https://<your-domain>/api/auth/callback/<provider>
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_LINKEDIN_ID=
AUTH_LINKEDIN_SECRET=
# [OPTIONAL] ORCID (academic identity). ISSUER defaults to https://orcid.org.
# NOTE: ORCID returns no email, so ORCID sign-ins are routed through the email
# OTP step (needs RESEND below) to obtain a verified email.
AUTH_ORCID_ID=
AUTH_ORCID_SECRET=
AUTH_ORCID_ISSUER=https://orcid.org
# [OPTIONAL] Microsoft Entra (work, school, and personal Microsoft accounts).
# Register a multitenant Entra app, set the two below, and ALSO flip
# NEXT_PUBLIC_AUTH_MICROSOFT_ENABLED=true so the "Continue with Microsoft" button
# shows (it stays hidden until then so it never dead-ends). Redirect URI to add
# in Azure: https://<your-domain>/api/auth/callback/microsoft-entra-id (and
# http://localhost:3000/api/auth/callback/microsoft-entra-id for local dev).
# Leave AUTH_MICROSOFT_ENTRA_ID_ISSUER unset to default to the common tenant
# (multitenant + personal).
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
NEXT_PUBLIC_AUTH_MICROSOFT_ENABLED=

# ─────────────────────────────────────────────────────────────────────────────
# Database — Neon Postgres (serverless)
# ─────────────────────────────────────────────────────────────────────────────
# [REQUIRED for sharing] Backs the identity directory AND the relay inbox.
# Needs the pg_trgm extension (created automatically for trigram search).
DATABASE_URL=

# [REQUIRED for sharing] HMAC pepper used to hash emails before they are stored,
# so the directory only ever holds keyed hashes, never raw addresses. Generate a
# long random string (e.g. openssl rand -hex 32) and keep it stable forever;
# changing it orphans every existing directory entry.
DIRECTORY_HMAC_PEPPER=

# ─────────────────────────────────────────────────────────────────────────────
# Rate limiting — Upstash Redis
# ─────────────────────────────────────────────────────────────────────────────
# [REQUIRED for sharing] The code reads the KV_REST_API_* names (set by the
# Vercel <-> Upstash integration), NOT UPSTASH_REDIS_REST_*. Adding the Upstash
# Redis integration on Vercel populates both automatically.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Relay storage — Cloudflare R2
# ─────────────────────────────────────────────────────────────────────────────
# [REQUIRED for file sharing] Stores the end-to-end-encrypted shared bundles.
# The bytes are sealed client-side; R2 never sees plaintext.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ─────────────────────────────────────────────────────────────────────────────
# Email — Resend
# ─────────────────────────────────────────────────────────────────────────────
# [REQUIRED for sharing] Sends the 6-digit email OTP + share invites. ORCID
# sign-in depends on this path (see ORCID note above).
RESEND_API_KEY=
# The From: address (must be a verified Resend domain).
RESEND_INVITE_FROM=ResearchOS <no-reply@your-domain>
# Physical mailing address shown in the email footer (anti-spam compliance).
RESEND_POSTAL_ADDRESS=

# ─────────────────────────────────────────────────────────────────────────────
# Public + misc
# ─────────────────────────────────────────────────────────────────────────────
# [REQUIRED for sharing] Your production origin, used to build links in the
# OTP / invite emails. No trailing slash.
NEXT_PUBLIC_APP_ORIGIN=https://your-domain

# [OPTIONAL] Suppress the v4 onboarding tour ("true" to disable).
NEXT_PUBLIC_DISABLE_V4_TOUR=

# [OPTIONAL] Real-time collaboration relay (Phase 3, not launched). Leave unset.
# When set to a wss:// origin it is also auto-added to the CSP connect-src.
NEXT_PUBLIC_COLLAB_RELAY_URL=

# [OPTIONAL] Inventory v1 feature flag. Set to "1" (or "true") to enable the
# /inventory route, purchases supplies tab, and PO status control. Default OFF
# when unset. Prod stays OFF until inventory bug fixes land; flipping it on is a
# deliberate Vercel env action + redeploy, not a code change.
NEXT_PUBLIC_INVENTORY_ENABLED=

# [OPTIONAL] Spatial inventory layers — DORMANT, default OFF. Set to "1" (or
# "true") to revive the structured box-finder (Phase B: freezer -> rack -> box ->
# cell picker + Storage map tree) AND the 2D/3D room map (Phase C: RoomMap, pins,
# floor-plan templates, location photos, external-storage, the unbuilt RoomPlan
# 3D scan). Cut 2026-06-16 (Grant) in favor of the free-text location box alone --
# real labs label their own drawers. Independent of NEXT_PUBLIC_INVENTORY_ENABLED;
# the free-text location stays ON regardless. Mobile mirror flag (Expo):
# EXPO_PUBLIC_SPATIAL_INVENTORY_ENABLED, same default-OFF semantics.
NEXT_PUBLIC_SPATIAL_INVENTORY_ENABLED=

# ─────────────────────────────────────────────────────────────────────────────
# Metered-storage billing — Stripe (dark unless BILLING_ENABLED is "true")
# ─────────────────────────────────────────────────────────────────────────────
# Hybrid metered model (1 GB free, then $0.30/GB-month of average use, one
# monthly invoice, $2 minimum). The whole billing surface fails closed unless
# this is "true".
BILLING_ENABLED=
# Dev uses the TEST keys (sk_test_ / pk_test_); set the LIVE keys (sk_live_ /
# pk_live_) ONLY in the production environment, never in a dev .env.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret. Local: `stripe listen --forward-to
# localhost:3000/api/billing/webhook` prints a whsec_. Prod: the hosted endpoint
# has its own separate secret.
STRIPE_WEBHOOK_SECRET=
# The METERED storage price the checkout subscribes to (a per-GB-month metered
# price backed by a Stripe Billing Meter, priced at $0.30/unit where unit = 1 GB).
STRIPE_STORAGE_PRICE_ID=
# The Billing Meter's event_name. The monthly report cron sends usage as meter
# events with this name; the metered price turns them into the invoice line.
STRIPE_METER_EVENT_NAME=
# [OPTIONAL] Origin for the checkout success/cancel return URLs. Defaults to the
# request origin if unset.
BILLING_RETURN_ORIGIN=
# CRON_SECRET secures the cron endpoints (Vercel Cron sends it as a Bearer token).
# Shared with the business-reminders cron. Set in env; the crons 404 without it.
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Lab companion sites + BYO ("bring your own") static-site hosting [OPTIONAL]
# ─────────────────────────────────────────────────────────────────────────────
# Paid-lab companion sites at research-os.app/<slug>. Two-layer flags, default
# OFF (the app is byte-identical with them unset). Server gates are read lazily
# at request time; NEXT_PUBLIC_* client gates are inlined at build time.
LAB_SITES_ENABLED=
NEXT_PUBLIC_LAB_SITES=
# BYO sub-flag (layered ON TOP of the lab-sites gates): host a lab's OWN static
# site (uploaded zip OR a connected PUBLIC GitHub repo). Requires BOTH the
# lab-sites gate above AND this to be on.
LAB_BYO_SITES=
NEXT_PUBLIC_LAB_BYO_SITES=
# [OPTIONAL] GitHub-connect (BYO source from a PUBLIC repo's zipball). A token is
# NOT required for public repos; when set it is sent as a Bearer token, which
# raises GitHub's 60/hr unauthenticated rate limit (and is the hook for private
# repos in a later slice). A fine-grained PAT with public read is plenty.
GITHUB_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Auto-set by Vercel — do NOT set these manually
# ─────────────────────────────────────────────────────────────────────────────
# VERCEL_GIT_COMMIT_SHA, NEXT_PUBLIC_RESEARCHOS_COMMIT / RESEARCHOS_COMMIT_SHA,
# NODE_ENV. The welcome-page demo videos load from public Vercel Blob URLs
# hardcoded in the page, so they need no runtime env (BLOB_READ_WRITE_TOKEN is
# only needed if you re-upload them).
