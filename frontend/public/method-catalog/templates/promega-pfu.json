  "description": "Promega Pfu DNA Polymerase: 50 uL high-fidelity reaction with a slow ~2 min/kb extension.",
  "category": "Molecular biology",
  "method_type": "pcr",
  "tags": ["pcr", "promega", "pfu", "high-fidelity"],
