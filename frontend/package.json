{
  "name": "frontend",
  "version": "0.75.0",
  "private": true,
  "packageManager": "pnpm@10.34.3",
  "author": "Grant R. Nickles <gnickles@wisc.edu>",
  "license": "AGPL-3.0-or-later",
  "funding": {
    "type": "grant",
    "url": "https://rise.wisc.edu/"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "build:duckdb-bundle": "node scripts/build-duckdb-bundle.mjs",
    "prebuild": "node ../scripts/check-wiki-coverage.mjs --ci && node ../scripts/build-wiki-content.mjs && node ../scripts/build-wiki-search-index.mjs --quiet && node ../scripts/build-demo-zip.mjs && node ../scripts/build-ai-helper.mjs && node ../scripts/check-ai-helper.mjs && node ../scripts/build-open-source-credits.mjs",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "wiki:screenshots": "node ../scripts/capture-wiki-screenshots.mjs",
    "wiki:coverage": "node ../scripts/check-wiki-coverage.mjs",
    "wiki:search-index": "node ../scripts/build-wiki-search-index.mjs",
    "wiki:content": "node ../scripts/build-wiki-content.mjs && cp public/wiki-content.json ../mobile/assets/wiki-content.json",
    "demo:data": "node ../scripts/generate-demo-data.mjs",
    "demo:images": "node ../scripts/generate-demo-images.mjs",
    "demo:zip": "node ../scripts/build-demo-zip.mjs",
    "ai-helper:build": "node ../scripts/build-ai-helper.mjs",
    "ai-helper:check": "node ../scripts/check-ai-helper.mjs",
    "ai-helper:refresh": "node ../scripts/build-ai-helper.mjs && (cd .. && git add frontend/public/ai-helper 2>/dev/null; git diff --cached --quiet || git commit -m 'AI Helper: refresh prompts (auto)')",
    "credits:build": "node ../scripts/build-open-source-credits.mjs",
    "credits:check": "node ../scripts/build-open-source-credits.mjs --check",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1059.0",
    "@aws-sdk/s3-request-presigner": "^3.1059.0",
    "@codemirror/commands": "6.10.3",
